# Auta Configuration Template
# Copy this file to .env and fill in your values
# DO NOT COMMIT .env - it's in .gitignore

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection URL for production/development
# Format: postgres://user:password@host:port/database?sslmode=disable
DATABASE_URL="postgres://auta:auta_dev_password@localhost/auta?sslmode=disable"

# PostgreSQL test database URL (for running tests)
TEST_DATABASE_URL="postgres://auta:auta_test_password@localhost:5433/auta_test?sslmode=disable"

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Port the metadata service runs on
PORT=8000

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Service environment (development, staging, production)
ENVIRONMENT=development

# ============================================================================
# SECURITY & AUTHENTICATION (Future Use)
# ============================================================================

# JWT secret for signing authentication tokens
JWT_SECRET="your-secure-jwt-secret-min-32-chars"

# API key for service-to-service communication
API_KEY_SECRET="your-api-key-secret"

# Node authentication key (for storage nodes to authenticate)
NODE_AUTH_KEY="your-node-authentication-key"

# ============================================================================
# ENCRYPTION (Future Use)
# ============================================================================

# Master key for encrypting wrapped file keys
MASTER_ENCRYPTION_KEY="your-master-encryption-key-base64"

# ============================================================================
# CLOUD/INFRASTRUCTURE (Future Use)
# ============================================================================

# AWS Configuration (if using AWS)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"

# GCP Configuration (if using Google Cloud)
GCP_PROJECT_ID="your-gcp-project"
GCP_CREDENTIALS_JSON="path-to-credentials-json"

# ============================================================================
# EXTERNAL SERVICES (Future Use)
# ============================================================================

# Slack webhook for notifications
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"

# Sentry for error tracking
SENTRY_DSN="https://key@sentry.io/project"

# ============================================================================
# MONITORING & OBSERVABILITY (Future Use)
# ============================================================================

# Datadog API key
DATADOG_API_KEY="your-datadog-api-key"

# New Relic license key
NEWRELIC_LICENSE_KEY="your-newrelic-license"

# ============================================================================
# DEBUGGING (Development Only)
# ============================================================================

# Enable verbose logging
DEBUG=false

# Enable profiling (pprof)
PROFILING_ENABLED=false

# Path for profiling output
PROFILING_PATH="/tmp/profiles"

# ============================================================================
# NOTES
# ============================================================================

# DO NOT COMMIT this file with real values!
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. .env is in .gitignore and won't be committed
# 4. Never commit .env - it contains secrets

# For team collaboration:
# - Share .env.example (this file) with the team
# - Share actual secrets through secure channels only
# - Use your deployment platform's secret management for production
